# ---- SakhiSign Node/Express backend ----
PORT=4000

# MongoDB Atlas connection string (free tier).
# Get it from: Atlas > Database > Connect > Drivers. Replace <user>, <pass>, <cluster>.
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sakhisign?retryWrites=true&w=majority

# JWT signing secret - use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Python FastAPI AI service base URL.
AI_SERVICE_URL=http://localhost:8000

# Comma-separated list of allowed frontend origins (Vite dev server default below).
CORS_ORIGIN=http://localhost:5173

# Score at/above which a sign counts as "mastered" on the dashboard.
MASTERY_THRESHOLD=80
